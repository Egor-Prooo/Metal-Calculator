@{
    ViewData["Title"] = "Калкулатор за тегло на метали";
}

<div class="calculator-container">
    <div class="sidebar">
        <h3 data-translate="pageTitle">@ViewData["Title"]</h3>

        <div class="form-group">
            <label for="productSelect" data-translate="selectProduct">Изберете продукт:</label>
            <select id="productSelect" class="form-control" onchange="onProductChange(this.value)">
                <option value="" data-translate="choose">-- Изберете --</option>
                <option value="wire" data-translate="wire">Тел/катанка</option>
                <option value="square" data-translate="square">Квадрат</option>
                <option value="hexagon" data-translate="hexagon">Шестоъгълник</option>
                <option value="corner" data-translate="corner">Ъглов профил</option>
                <option value="sheet" data-translate="sheet">Лист</option>
                <option value="pipe" data-translate="pipe">Тръба</option>
                <option value="squarePipe" data-translate="squarePipe">Квадратна тръба</option>
                <option value="channel" data-translate="channel">П-профил</option>
                <option value="strip" data-translate="strip">Лента</option>
                <option value="flatbar" data-translate="flatbar">Шина</option>
                <option value="beam" data-translate="beam">HEA</option>
            </select>
        </div>

        <div class="form-group">
            <label for="metalSelect" data-translate="selectMetal">Изберете метал:</label>
            <select id="metalSelect" class="form-control">
                <option value="" data-translate="choose">-- Изберете --</option>
                <option value="copper" data-translate="copper">Мед</option>
                <option value="bronze" data-translate="bronze">Бронз</option>
                <option value="aluminum" data-translate="aluminum">Алуминий</option>
                <option value="zinc" data-translate="zinc">Цинк</option>
                <option value="tin" data-translate="tin">Калай</option>
                <option value="steel" data-translate="steel">Стомана</option>
                <option value="lead" data-translate="lead">Олово</option>
                <option value="titanium" data-translate="titanium">Титан</option>
                <option value="nickel" data-translate="nickel">Никел</option>
                <option value="brass" data-translate="brass">Месинг</option>
            </select>
        </div>

        <!-- Cost Estimator -->
        <div class="form-group cost-group">
            <label data-translate="pricePerKg">Цена / кг:</label>
            <div class="cost-inputs">
                <input type="number" step="any" id="pricePerKg" class="form-control cost-price"
                       placeholder="0.00" autocomplete="off" />
                <input type="text" id="currency" class="form-control cost-currency"
                       placeholder="Cur." maxlength="5" autocomplete="off" />
            </div>
        </div>

        <!-- Unit Toggle -->
        <div class="form-group">
            <label data-translate="units">Единици:</label>
            <button class="btn btn-secondary unit-toggle-btn" onclick="toggleUnits()">Метрични</button>
        </div>

        <!-- Reverse Mode -->
        <div class="form-group">
            <button id="reverseModeBtn" class="btn reverse-mode-btn" onclick="toggleReverseMode()"
                    data-translate="reverseMode">
                ⇄ Обратно изчисление
            </button>
        </div>

        <!-- Presets Section -->
        <div class="presets-section">
            <h4 data-translate="presets">Шаблони</h4>
            <button class="btn btn-success" onclick="savePreset()" data-translate="savePreset">Запази шаблон</button>
            <div id="presetsContainer" class="presets-list">
                <p class="no-presets" data-translate="noPresets">Няма запазени шаблони</p>
            </div>
        </div>

        <!-- History Section -->
        <div class="presets-section history-section">
            <div class="history-header">
                <h4 data-translate="history">История</h4>
                <button class="btn-clear-history" onclick="clearHistory()" data-translate="clearHistory">Изчисти</button>
            </div>
            <div id="historyContainer" class="presets-list">
                <p class="no-presets" data-translate="noHistory">Няма история</p>
            </div>
        </div>
    </div>

    <!-- Language Selector -->
    <div id="languageSelector">
        <button onclick="setLanguage('bg')">BG</button>
        <button onclick="setLanguage('en')">EN</button>
        <button onclick="setLanguage('ru')">RU</button>
        <button onclick="setLanguage('tr')">TR</button>
        <button onclick="setLanguage('de')">DE</button>
        <button onclick="setLanguage('el')">GR</button>
        <button onclick="setLanguage('ro')">RO</button>
    </div>

    <!-- Content Area -->
    <div class="content">
        <h4 id="diagramTitle" data-translate="pleaseSelectProduct">Моля изберете продукт</h4>
        <img id="diagramImage" src="" class="diagram" style="display:none;" />

        <div id="dynamicInputs" class="input-fields"></div>

        <br />

        <button id="calcBtn" class="btn btn-primary" onclick="calculateWeight()" data-translate="calculateWeight">
            Изчисли теглото
        </button>

        <br />

        <p data-translate="result">Резултат:</p>
        <div id="result" class="result-output"></div>
    </div>
</div>

@section Scripts {
    <script src="~/js/translations.js"></script>
    <script src="~/js/site.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            translateUI();
        });
    </script>
}